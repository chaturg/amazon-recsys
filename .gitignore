*.pt
*.bin
*.safetensors
*.pkl
*.ids.pkl

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
nohup.out
pipeline_run.log
ce_pairs_run.log
synthetic_queries_run.log

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ── Azure ML ──────────────────────────────────────────────────────────────────
.azureml/
azureml-logs/
azureml_runs/

# ── HF cache ──────────────────────────────────────────────────────────────────
.cache/
/tmp/recsys/

# ── Secrets — never commit API keys ──────────────────────────────────────────
.env.local
secrets.json
*_token.txt

